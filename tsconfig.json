{
	"compilerOptions": {
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"lib": ["ES2020", "DOM"],
		"outDir": "./dist"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
